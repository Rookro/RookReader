  "query": "\n            SELECT\n                b.id,\n                b.file_path,\n                b.item_type,\n                b.display_name,\n                b.total_pages,\n                b.series_id,\n                b.series_order,\n                b.thumbnail_path,\n                r.last_read_page_index,\n                r.last_opened_at,\n                (SELECT GROUP_CONCAT(tag_id) FROM book_tags WHERE book_id = b.id) as \"tag_ids_str?: String\"\n            FROM books b\n            LEFT JOIN\n                reading_state r ON b.id = r.book_id\n            WHERE\n                b.id = ?\n            ",
