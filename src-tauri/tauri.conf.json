{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RookReader",
  "version": "2.0.3",
  "identifier": "io.github.rookro.rookreader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rook Reader",
        "width": 1000,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/thumbnails/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "target/dependencies/pdfium/LICENSE": "licenses/pdfium/LICENSE",
      "target/dependencies/pdfium/licenses/**/*": "licenses/pdfium/",
      "target/dependencies/licenses/frontend-licenses.txt": "licenses/frontend-licenses.txt",
      "target/dependencies/licenses/backend-licenses.html": "licenses/backend-licenses.html"
    },
    "licenseFile": "../LICENSE",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxOTAwNTE4OEY5RDhGMEYKUldRUGo1MlBHQVdRWVFTM1o5OG1QSEMvQ0czMEt1MUdGbVhXNFJTQzIzbXdOV1BnQmlFMTJ2bSsK",
      "endpoints": [
        "https://github.com/Rookro/RookReader/releases/latest/download/latest.json"
      ]
    }
  }
}
